{
  "name": "@maka/headless",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./prompt-optimization-env": {
      "types": "./dist/prompt-optimization-env.d.ts",
      "default": "./dist/prompt-optimization-env.js"
    }
  },
  "bin": {
    "maka-headless": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@maka/core": "0.1.0",
    "@maka/runtime": "0.1.0",
    "@maka/storage": "0.1.0"
  }
}
